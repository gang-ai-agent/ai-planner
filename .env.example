APP_NAME="AI Vacation Planner"
ENVIRONMENT=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://planner:planner@localhost:5432/ai_planner
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_ENABLED=true
QDRANT_MEMORY_ENABLED=false
QDRANT_TRAVEL_COLLECTION=trips
DEFAULT_EMBEDDING_DIM=768
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-vacation-planner
LLM_ENABLED=false
LLM_PROVIDER=local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=granite4.1:3b
OLLAMA_TIMEOUT_SECONDS=10
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
OLLAMA_EMBEDDING_TIMEOUT_SECONDS=15
RETRIEVAL_QUERY_LANGUAGE=zh
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
